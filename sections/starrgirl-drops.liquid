{% comment %}
  StarrGirl Upcoming Drops & Big News Section
  Configurable news/announcement cards (1-3)
{% endcomment %}

<section class="sg-drops-section color-{{ section.settings.color_scheme }}">
  <div style="max-width:1100px; margin:0 auto; padding:0 48px;">

    <div style="margin-bottom:40px;">
      {% if section.settings.eyebrow != blank %}
        <span class="sg-section-tag">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="sg-section-title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
        <p class="sg-section-sub">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    <div class="sg-drops-grid" style="grid-template-columns: repeat({{ section.blocks.size }}, 1fr);">
      {% for block in section.blocks %}
        <div class="sg-drop-card" {{ block.shopify_attributes }}>
          {% if block.settings.badge != blank %}
            <div class="sg-status-badge sg-status-badge--{{ block.settings.badge_style }}">
              {{ block.settings.badge_icon }} {{ block.settings.badge }}
            </div>
          {% endif %}
          <div class="sg-drop-card__title">{{ block.settings.title }}</div>
          {% if block.settings.date != blank %}
            <div class="sg-drop-card__date">{{ block.settings.date }}</div>
          {% endif %}
          {% if block.settings.text != blank %}
            <div class="sg-drop-card__text">{{ block.settings.text }}</div>
          {% endif %}
          {% if block.settings.link_label != blank and block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="sg-drop-card__link">{{ block.settings.link_label }}</a>
          {% endif %}
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .sg-drops-section {
    background: #FFF0F8;
    padding: 64px 0;
  }
  .sg-drops-grid {
    display: grid;
    gap: 20px;
  }
  @media (max-width: 768px) {
    .sg-drops-grid { grid-template-columns: 1fr !important; }
    .sg-drops-section { padding: 48px 0; }
    .sg-drops-section > div { padding: 0 20px !important; }
  }
</style>

{% schema %}
{
  "name": "StarrGirl Drops & News",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "🔥 WHAT'S COMING"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Upcoming Drops & Big News! 🌟"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Stay in the loop! New drops, pre-sales, and big Starr Girls moments — all right here. 💖"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "scheme-1", "label": "White" },
        { "value": "scheme-2", "label": "Pink Pale" }
      ],
      "default": "scheme-2",
      "label": "Color scheme"
    }
  ],
  "blocks": [
    {
      "type": "drop_card",
      "name": "Drop Card",
      "settings": [
        {
          "type": "text",
          "id": "badge",
          "label": "Status Badge Text",
          "default": "AVAILABLE NOW"
        },
        {
          "type": "text",
          "id": "badge_icon",
          "label": "Badge Icon",
          "default": "✨"
        },
        {
          "type": "select",
          "id": "badge_style",
          "label": "Badge Color",
          "options": [
            { "value": "available", "label": "Pink (Available)" },
            { "value": "coming", "label": "Yellow (Coming Soon)" },
            { "value": "tours", "label": "Purple (Tours/Events)" }
          ],
          "default": "available"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "The First Collection 🌟"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date / Status",
          "default": "Live Now — Pre-Order, Ships 3-4 Weeks"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Shop individual pieces — tops, bottoms, bows, and socks in limited edition coordinating colorways."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label",
          "default": "Shop Now ✨ →"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "StarrGirl Drops & News",
      "blocks": [
        {
          "type": "drop_card",
          "settings": {
            "badge": "AVAILABLE NOW",
            "badge_icon": "✨",
            "badge_style": "available",
            "title": "The First Collection 🌟",
            "date": "Live Now — Pre-Order, Ships 3-4 Weeks",
            "text": "The debut Starr Girls collection! Shop individual pieces — tops, bottoms, bows, and socks.",
            "link_label": "Shop Now ✨ →"
          }
        }
      ]
    }
  ]
}
{% endschema %}
