{% comment %}
  StarrGirl Club Signup Section with COPPA Age Gate
  Includes: age gate → 13+ form / under-13 parent form
{% endcomment %}

<div class="sg-club-section color-{{ section.settings.color_scheme }}">
  <div class="sg-club-inner">

    <div style="text-align:center; margin-bottom: 32px;">
      <span class="sg-section-tag">💖 THE STARR GIRLS CLUB</span>
      <h2 class="sg-section-title">{{ section.settings.heading }}</h2>
      {% if section.settings.subtext != blank %}
        <p class="sg-section-sub" style="margin: 0 auto;">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    <!-- Age Gate -->
    <div id="sg-age-gate" class="sg-age-gate">
      <div class="sg-age-gate__icon">🎂</div>
      <div class="sg-age-gate__title">Are you 13 or older?</div>
      <p class="sg-age-gate__sub">We need to know before you join. If you're under 13, a parent or guardian should sign up on your behalf.</p>
      <div class="sg-age-buttons">
        <button class="sg-btn sg-btn--pink" onclick="showForm13()">Yes, I'm 13+ 🌟</button>
        <button class="sg-btn sg-btn--yellow" onclick="showFormParent()">Get a parent 👨‍👩‍👧</button>
      </div>
    </div>

    <!-- 13+ Signup Form -->
    <div id="sg-form-13" class="sg-signup-wrap" style="display:none;">
      <p style="font-size:12px; color:#aaa; text-align:center; margin-bottom:20px;">We'll never share your info. Unsubscribe anytime.</p>
      {% form 'customer', id: 'sg-newsletter-13' %}
        <input type="hidden" name="contact[tags]" value="newsletter,starrgirl-club,13-plus">
        <div class="sg-form-row">
          <div class="sg-field">
            <input type="text" name="contact[first_name]" placeholder="First name 💖" class="sg-input" required>
          </div>
          <div class="sg-field">
            <input type="text" name="contact[last_name]" placeholder="Last name" class="sg-input">
          </div>
        </div>
        <div class="sg-field">
          <input type="email" name="contact[email]" placeholder="Email address 🔵" class="sg-input" required>
        </div>
        <div class="sg-field">
          <input type="tel" name="contact[phone]" placeholder="Phone (optional — for drop alerts 📱)" class="sg-input">
        </div>
        <button type="submit" class="sg-btn sg-btn--signup sg-btn--full">
          Join the Starr Girls Club ⭐
        </button>
        <p style="font-size:12px; color:#aaa; text-align:center; margin-top:10px;">We'll never share your info. Unsubscribe anytime.</p>
      {% endform %}
    </div>

    <!-- Parent Signup Form (Under 13 / COPPA) -->
    <div id="sg-form-parent" class="sg-signup-wrap" style="display:none;">
      <div class="sg-coppa-notice">
        👨‍👩‍👧 Under COPPA, a parent or guardian must sign up for children under 13. Thank you for keeping your Starr Girl safe!
      </div>
      {% form 'customer', id: 'sg-newsletter-parent' %}
        <input type="hidden" name="contact[tags]" value="newsletter,starrgirl-club,parent-signup,under-13">
        <div class="sg-form-row">
          <div class="sg-field">
            <input type="text" name="contact[first_name]" placeholder="Parent first name" class="sg-input" required>
          </div>
          <div class="sg-field">
            <input type="text" name="contact[last_name]" placeholder="Parent last name" class="sg-input" required>
          </div>
        </div>
        <div class="sg-field">
          <input type="email" name="contact[email]" placeholder="Parent email 🔵" class="sg-input" required>
        </div>
        <div class="sg-field">
          <input type="tel" name="contact[phone]" placeholder="Parent phone (optional 📱)" class="sg-input">
        </div>
        <div class="sg-field">
          <input type="text" name="contact[note]" placeholder="Your daughter's first name 💖" class="sg-input">
        </div>
        <button type="submit" class="sg-btn sg-btn--signup sg-btn--full">
          Sign Up for My Daughter ⭐
        </button>
        <p style="font-size:12px; color:#aaa; text-align:center; margin-top:10px;">By signing up you confirm you are the parent or legal guardian. You may request deletion of data at any time.</p>
      {% endform %}
    </div>

    <!-- Success Message (shown on return after form submit) -->
    {%- if customer -%}
    <div class="sg-confirmation" style="max-width:480px; margin:0 auto; text-align:left;">
      <div class="sg-confirmation__title">⭐ You're in!</div>
      <p>Welcome to the Starr Girls Club, {{ customer.first_name }}! 💖<br>
      Check your inbox for a confirmation — and get ready for early drop access!</p>
    </div>
    {%- endif -%}

  </div>
</div>

<style>
  .sg-club-section {
    background: #FFF0F8;
    padding: 72px 48px;
    text-align: center;
  }
  .sg-club-inner {
    max-width: 560px;
    margin: 0 auto;
  }
  .sg-age-gate {
    background: #fff;
    border: 3px solid #1a1a1a;
    border-radius: 20px;
    padding: 28px;
    box-shadow: 5px 5px 0 #1a1a1a;
    text-align: center;
    margin-bottom: 24px;
  }
  .sg-age-gate__icon { font-size: 32px; margin-bottom: 10px; }
  .sg-age-gate__title {
    font-family: 'Fredoka One', cursive;
    font-size: 20px;
    color: #FF2090;
    margin-bottom: 8px;
  }
  .sg-age-gate__sub {
    font-size: 14px;
    color: #666;
    font-weight: 600;
    margin-bottom: 22px;
    line-height: 1.5;
  }
  .sg-age-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .sg-btn {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 50px;
    font-family: 'Fredoka One', cursive;
    font-size: 15px;
    border: 3px solid #1a1a1a;
    box-shadow: 3px 3px 0 #1a1a1a;
    cursor: pointer;
    transition: transform 0.1s, box-shadow 0.1s;
    text-decoration: none;
  }
  .sg-btn:hover {
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0 #1a1a1a;
  }
  .sg-btn--pink { background: #FF2090; color: #fff; }
  .sg-btn--yellow { background: #FFE566; color: #1a1a1a; }
  .sg-btn--signup {
    background: #FF2090;
    color: #fff;
    border-radius: 14px;
    font-size: 17px;
    padding: 16px;
    width: 100%;
    border: 3px solid #1a1a1a;
    box-shadow: 4px 4px 0 #1a1a1a;
    cursor: pointer;
    margin-top: 8px;
  }
  .sg-btn--full { display: block; width: 100%; }
  .sg-signup-wrap {
    text-align: left;
    background: #fff;
    border: 3px solid #1a1a1a;
    border-radius: 20px;
    padding: 28px;
    box-shadow: 5px 5px 0 #1a1a1a;
  }
  .sg-form-row {
    display: flex;
    gap: 12px;
    margin-bottom: 14px;
  }
  .sg-form-row .sg-field { flex: 1; }
  .sg-field { margin-bottom: 14px; }
  .sg-input {
    width: 100%;
    padding: 14px 18px;
    border: 3px solid #FFB3DC;
    border-radius: 14px;
    font-size: 15px;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    background: #fff;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }
  .sg-input:focus {
    border-color: #FF2090;
    outline: none;
  }
  .sg-coppa-notice {
    background: #FFF0F8;
    border: 2px solid #FFB3DC;
    border-radius: 12px;
    padding: 14px 16px;
    font-size: 13px;
    font-weight: 700;
    color: #555;
    margin-bottom: 20px;
    line-height: 1.5;
  }
  @media (max-width: 600px) {
    .sg-club-section { padding: 48px 20px; }
    .sg-form-row { flex-direction: column; }
  }
</style>

<script>
function showForm13() {
  document.getElementById('sg-age-gate').style.display = 'none';
  document.getElementById('sg-form-13').style.display = 'block';
}
function showFormParent() {
  document.getElementById('sg-age-gate').style.display = 'none';
  document.getElementById('sg-form-parent').style.display = 'block';
}
</script>

{% schema %}
{
  "name": "StarrGirl Club Signup",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Be First for Every Drop ⭐"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Drop alerts, early access, and member-only perks — straight to your phone or inbox. Free to join."
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "scheme-1", "label": "White" },
        { "value": "scheme-2", "label": "Pink Pale" },
        { "value": "scheme-3", "label": "Dark" }
      ],
      "default": "scheme-2",
      "label": "Color scheme"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "StarrGirl Club Signup"
    }
  ]
}
{% endschema %}
