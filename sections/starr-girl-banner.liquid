{{ 'starr-girl-banner.css' | asset_url | stylesheet_tag }}

<section class="sg-banner" style="
  {% if section.settings.use_gradient %}
    background: linear-gradient({{ section.settings.gradient_direction }}deg, {{ section.settings.gradient_color_1 }}, {{ section.settings.gradient_color_2 }});
  {% else %}
    background-color: {{ section.settings.bg_color }};
  {% endif %}
  {% if section.settings.bg_image != blank %}
    background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');
    background-size: cover;
    background-position: center;
  {% endif %}
">
  <div class="sg-banner__overlay" style="background: linear-gradient(to bottom, rgba(26,10,20,{{ section.settings.overlay_opacity | divided_by: 100.0 }}) 0%, rgba(26,10,20,{{ section.settings.overlay_opacity | divided_by: 100.0 | times: 2 | at_most: 1 }}) 100%);"></div>

  <div class="sg-banner__content">

    {% if section.settings.tag_text != blank %}
      <div class="sg-banner__tag">{{ section.settings.tag_text }}</div>
    {% endif %}

    {% if section.settings.logo_image != blank %} 
      <div class="sg-banner__logo-wrap">
        <img
          src="{{ section.settings.logo_image | img_url: 'master' }}"
          alt="{{ section.settings.logo_image.alt | default: shop.name }}"
          class="sg-banner__logo"
          width="{{ section.settings.logo_width }}"
          loading="eager"
        >
      </div>
    {% endif %}

    {% if section.settings.description != blank %}
      <p class="sg-banner__description">{{ section.settings.description }}</p>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <div class="sg-banner__buttons">
        <a href="{{ section.settings.button_link }}" class="sg-banner__btn">
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .sg-banner {
    position: relative;
    min-height: {{ section.settings.banner_height }}vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .sg-banner__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .sg-banner__content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    padding: 40px 24px;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .sg-banner__tag {
    display: inline-block;
    background: rgba(255, 32, 144, 0.15);
    border: 1px solid rgba(255, 32, 144, 0.5);
    color: #FFB3DC;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 18px;
    border-radius: 50px;
    margin-bottom: 24px;
  }

  #shopify-section-{{ section.id }} .sg-banner__logo-wrap {
    margin: 0 auto 28px;
  }

  #shopify-section-{{ section.id }} .sg-banner__logo {
    max-width: {{ section.settings.logo_width }}px;
    width: 100%;
    filter: drop-shadow(0 4px 24px rgba(255, 32, 144, 0.5));
  }

  #shopify-section-{{ section.id }} .sg-banner__description {
    font-size: clamp(18px, 2.5vw, 28px);
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 36px;
    letter-spacing: 0.5px;
    font-weight: 700;
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .sg-banner__buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .sg-banner__btn {
    display: inline-block;
    background: {{ section.settings.button_color }};
    color: {{ section.settings.button_text_color }};
    padding: 12px 40px;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 900;
    text-decoration: none;
    box-shadow: 0 6px 24px rgba(255, 32, 144, 0.5);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    letter-spacing: 0.5px;
  }

  #shopify-section-{{ section.id }} .sg-banner__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(255, 32, 144, 0.65);
  }
</style>

{% schema %}
{
  "name": "StarrGirl Banner",
  "tag": "div",
  "class": "starrgirl-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image",
      "info": "If set, this overrides the gradient/color. Upload a photo of Nova here."
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use gradient background (when no image)",
      "default": true
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient — Start color",
      "default": "#2d0a1e"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient — End color",
      "default": "#5a1040"
    },
    {
      "type": "range",
      "id": "gradient_direction",
      "label": "Gradient direction (degrees)",
      "min": 0,
      "max": 360,
      "step": 10,
      "default": 160,
      "unit": "°"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Solid background color (fallback)",
      "default": "#2d0a1e"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Dark overlay opacity (when image is used)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner height",
      "min": 40,
      "max": 100,
      "step": 5,
      "default": 90,
      "unit": "vh"
    },
    {
      "type": "header",
      "content": "Tag (eyebrow label)"
    },
    {
      "type": "text",
      "id": "tag_text",
      "label": "Tag text",
      "default": "Nova Starr's Official Collection"
    },
    {
      "type": "header",
      "content": "Logo Image"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image",
      "info": "Upload the StarrGirl logo PNG with transparent background."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 100,
      "max": 600,
      "step": 10,
      "default": 460,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description text",
      "default": "Color-coordinated pieces for girls who show up, stand out, and own their space."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now ✨"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background color",
      "default": "#FF2090"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "StarrGirl Banner"
    }
  ]
}
{% endschema %}
